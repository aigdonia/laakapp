---
---

<section class="relative min-h-screen flex flex-col items-center overflow-hidden bg-surface">
  <!-- Background effects -->
  <div class="absolute top-[20%] start-1/2 -translate-x-1/2 w-[1000px] h-[600px] rounded-full bg-accent/[0.04] blur-[150px]"></div>

  <!-- Decorative floating shapes -->
  <div class="absolute top-[15%] end-[8%] w-20 h-20 sm:w-28 sm:h-28 opacity-60 animate-float-slow">
    <svg viewBox="0 0 100 100" fill="none">
      <path d="M20 50L50 20L80 50L50 80Z" stroke="#FFD60A" stroke-width="3" fill="#FFD60A" fill-opacity="0.1"/>
    </svg>
  </div>
  <div class="absolute top-[30%] start-[5%] w-16 h-16 sm:w-24 sm:h-24 opacity-40 animate-float-slower">
    <svg viewBox="0 0 100 100" fill="none">
      <circle cx="50" cy="50" r="35" stroke="#FFD60A" stroke-width="3" fill="#FFD60A" fill-opacity="0.08"/>
    </svg>
  </div>
  <div class="absolute top-[60%] end-[12%] w-12 h-12 sm:w-20 sm:h-20 opacity-30 animate-float-slow">
    <svg viewBox="0 0 100 100" fill="none">
      <path d="M10 50L50 10L90 50" stroke="#FFD60A" stroke-width="4" stroke-linecap="round" fill="none"/>
    </svg>
  </div>

  <!-- Main content -->
  <div class="relative z-10 flex flex-col items-center text-center pt-24 sm:pt-28 lg:pt-32 px-6 max-w-6xl mx-auto">

    <!-- Headline — display text -->
    <h1 class="font-heading font-black text-[clamp(2.5rem,6vw,5.5rem)] leading-[0.95] tracking-tight">
      YOUR MONEY
      <br />
      <span class="inline-flex items-center gap-3 sm:gap-5">
        YOUR
        <!-- Inline decorative chevrons -->
        <span class="inline-flex gap-1 shrink-0">
          <svg class="w-8 h-8 sm:w-14 sm:h-14 lg:w-16 lg:h-16 text-accent" viewBox="0 0 60 60" fill="currentColor"><path d="M15 5L45 30L15 55V5Z"/></svg>
          <svg class="w-8 h-8 sm:w-14 sm:h-14 lg:w-16 lg:h-16 text-accent/60" viewBox="0 0 60 60" fill="currentColor"><path d="M15 5L45 30L15 55V5Z"/></svg>
        </span>
        <span class="text-accent">RULES</span>
      </span>
      <br />
      <span class="inline-flex items-center gap-3 sm:gap-5">
        YOUR
        <!-- Inline decorative shield -->
        <span class="inline-block shrink-0">
          <svg class="w-10 h-10 sm:w-14 sm:h-14 lg:w-16 lg:h-16 text-accent" viewBox="0 0 60 60" fill="currentColor" fill-opacity="0.9"><path d="M30 5L52 15V30C52 44 30 55 30 55S8 44 8 30V15L30 5Z"/></svg>
        </span>
        DEVICE
      </span>
    </h1>

    <!-- Subtitle -->
    <p class="mt-6 sm:mt-8 text-text-secondary text-lg sm:text-xl max-w-2xl leading-relaxed">
      Investment portfolio tracker. Private. Offline. On your phone.
    </p>

    <!-- CTA Button (observed by nav to show/hide nav CTA) -->
    <div id="hero-ctas" class="mt-8 sm:mt-10">
      <a
        href="#"
        class="inline-flex items-center justify-center gap-2.5 bg-accent text-surface font-bold rounded-full px-8 py-4 text-base hover:scale-105 hover:shadow-[0_0_30px_rgba(255,214,10,0.3)] transition-all duration-200"
      >
        Download for free
      </a>
    </div>

    <!-- Stats row -->
    <div class="mt-10 sm:mt-12 flex items-center gap-6 sm:gap-10">
      <div class="text-center">
        <div class="font-heading font-extrabold text-2xl sm:text-3xl text-text-primary">620+</div>
        <div class="text-text-muted text-xs sm:text-sm mt-1">stocks covered</div>
      </div>
      <div class="w-px h-10 bg-white/10"></div>
      <div class="text-center">
        <div class="font-heading font-extrabold text-2xl sm:text-3xl text-text-primary">100%</div>
        <div class="text-text-muted text-xs sm:text-sm mt-1">on-device</div>
      </div>
      <div class="w-px h-10 bg-white/10"></div>
      <div class="text-center">
        <div class="font-heading font-extrabold text-2xl sm:text-3xl text-text-primary">3</div>
        <div class="text-text-muted text-xs sm:text-sm mt-1">markets</div>
      </div>
    </div>
  </div>

  <!-- Phone mockups — 3 phones, overlapping, below hero -->
  <div class="relative z-10 mt-16 sm:mt-20 w-full max-w-5xl mx-auto px-6 pb-8">
    <div class="relative flex items-end justify-center h-[340px] sm:h-[420px] lg:h-[500px]">

      <!-- Left phone (tilted) -->
      <div class="absolute start-[5%] sm:start-[10%] lg:start-[15%] bottom-0 w-[180px] sm:w-[220px] lg:w-[260px] -rotate-6 origin-bottom z-10">
        <div class="bg-surface-light rounded-[1.8rem] sm:rounded-[2.2rem] border border-white/10 overflow-hidden shadow-2xl aspect-[9/18]">
          <div class="absolute top-0 left-0 right-0 flex justify-center pt-1.5 z-10">
            <div class="w-20 h-5 bg-surface rounded-b-xl"></div>
          </div>
          <div class="p-3 pt-8 h-full bg-gradient-to-b from-surface-lighter/30 to-surface/80">
            <div class="text-[10px] text-text-secondary mb-2">Portfolio</div>
            <div class="flex items-center gap-2 mb-3">
              <div class="h-16 flex-1 flex items-end gap-0.5">
                <div class="flex-1 bg-accent/30 rounded-t" style="height: 45%"></div>
                <div class="flex-1 bg-accent/40 rounded-t" style="height: 60%"></div>
                <div class="flex-1 bg-accent/50 rounded-t" style="height: 40%"></div>
                <div class="flex-1 bg-accent/70 rounded-t" style="height: 75%"></div>
                <div class="flex-1 bg-accent rounded-t" style="height: 90%"></div>
              </div>
            </div>
            <div class="space-y-1.5">
              <div class="flex items-center gap-2 bg-white/5 rounded-lg p-2">
                <div class="w-5 h-5 rounded bg-red-400/20 flex items-center justify-center text-[8px] font-bold text-red-400">T</div>
                <span class="text-[10px] text-text-secondary flex-1">TSLA</span>
                <span class="text-[10px] text-text-primary">108.20</span>
              </div>
              <div class="flex items-center gap-2 bg-white/5 rounded-lg p-2">
                <div class="w-5 h-5 rounded bg-accent/20 flex items-center justify-center text-[8px] font-bold text-accent">C</div>
                <span class="text-[10px] text-text-secondary flex-1">COMI</span>
                <span class="text-[10px] text-text-primary">54.30</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Center phone (main, larger) -->
      <div class="relative z-20 w-[200px] sm:w-[250px] lg:w-[290px]">
        <div class="gold-glow absolute inset-0 rounded-[2rem] sm:rounded-[2.5rem]"></div>
        <div class="relative bg-surface-light rounded-[2rem] sm:rounded-[2.5rem] border-2 border-white/10 overflow-hidden shadow-2xl aspect-[9/18]">
          <div class="absolute top-0 left-0 right-0 flex justify-center pt-2 z-10">
            <div class="w-24 h-6 bg-surface rounded-b-2xl"></div>
          </div>
          <div class="p-4 pt-10 h-full bg-gradient-to-b from-surface-lighter/30 to-surface/80">
            <div class="flex items-center gap-2 mb-1">
              <img src="/images/laak-logo.svg" alt="" class="w-4 h-4 invert opacity-60" />
              <span class="text-[10px] text-text-secondary">Main portfolio</span>
            </div>
            <div class="flex items-center justify-between mb-3">
              <div class="text-lg sm:text-xl font-bold text-text-primary">EGP 142,500</div>
              <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m7 17 5-5 3 3 4-4"/><path d="M19 13v-2h-2"/></svg>
            </div>
            <!-- Chart -->
            <div class="h-20 sm:h-24 mb-3 relative">
              <svg class="w-full h-full" viewBox="0 0 200 80" preserveAspectRatio="none">
                <defs>
                  <linearGradient id="chartGrad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#FFD60A" stop-opacity="0.3"/>
                    <stop offset="100%" stop-color="#FFD60A" stop-opacity="0"/>
                  </linearGradient>
                </defs>
                <path d="M0 60 Q20 55 40 50 T80 35 T120 25 T160 30 T200 15" fill="none" stroke="#FFD60A" stroke-width="2.5"/>
                <path d="M0 60 Q20 55 40 50 T80 35 T120 25 T160 30 T200 15 V80 H0Z" fill="url(#chartGrad)"/>
              </svg>
            </div>
            <div class="flex items-center gap-2 bg-white/5 rounded-xl p-2.5">
              <div class="w-6 h-6 rounded-lg bg-accent/20 flex items-center justify-center">
                <span class="text-accent text-[8px] font-bold">B</span>
              </div>
              <div class="flex-1">
                <div class="text-[10px] font-medium text-text-primary">BTC</div>
              </div>
              <div class="text-end">
                <span class="text-[10px] text-red-400 font-medium">-2.56%</span>
                <svg class="w-3 h-3 text-red-400 inline-block ms-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m7 7 5 5 3-3 4 4"/></svg>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right phone (tilted) -->
      <div class="absolute end-[5%] sm:end-[10%] lg:end-[15%] bottom-0 w-[180px] sm:w-[220px] lg:w-[260px] rotate-6 origin-bottom z-10">
        <div class="bg-surface-light rounded-[1.8rem] sm:rounded-[2.2rem] border border-white/10 overflow-hidden shadow-2xl aspect-[9/18]">
          <div class="absolute top-0 left-0 right-0 flex justify-center pt-1.5 z-10">
            <div class="w-20 h-5 bg-surface rounded-b-xl"></div>
          </div>
          <div class="p-3 pt-8 h-full bg-gradient-to-b from-surface-lighter/30 to-surface/80">
            <div class="text-[10px] text-text-secondary mb-2">Screening</div>
            <div class="space-y-1.5 mt-1">
              <div class="flex items-center justify-between bg-accent/10 rounded-lg p-2">
                <span class="text-[10px] text-text-secondary">Debt Ratio</span>
                <span class="text-[10px] font-semibold text-accent">18.2%</span>
              </div>
              <div class="flex items-center justify-between bg-accent/10 rounded-lg p-2">
                <span class="text-[10px] text-text-secondary">Revenue</span>
                <span class="text-[10px] font-semibold text-accent">Pass</span>
              </div>
              <div class="flex items-center justify-between bg-accent/10 rounded-lg p-2">
                <span class="text-[10px] text-text-secondary">Interest</span>
                <span class="text-[10px] font-semibold text-accent">2.1%</span>
              </div>
              <div class="mt-2 flex justify-center">
                <div class="inline-flex items-center gap-1 bg-accent/20 rounded-full px-2.5 py-1">
                  <div class="w-1.5 h-1.5 rounded-full bg-accent"></div>
                  <span class="text-accent text-[9px] font-medium">Compliant</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
