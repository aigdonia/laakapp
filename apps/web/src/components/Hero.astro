---
import type { Locale } from '../i18n/config';
import { t } from '../i18n/utils';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
---

<section class="relative flex flex-col items-center bg-surface overflow-hidden">
  <!-- Background effects -->
  <div class="absolute top-[20%] start-1/2 -translate-x-1/2 w-[1000px] h-[600px] rounded-full bg-accent/[0.04] blur-[150px]"></div>

  <!-- Decorative floating shapes -->
  <div class="absolute top-[15%] end-[8%] w-20 h-20 sm:w-28 sm:h-28 opacity-60 animate-float-slow">
    <svg viewBox="0 0 100 100" fill="none">
      <path d="M20 50L50 20L80 50L50 80Z" stroke="#FFD60A" stroke-width="3" fill="#FFD60A" fill-opacity="0.1"/>
    </svg>
  </div>
  <div class="absolute top-[30%] start-[5%] w-16 h-16 sm:w-24 sm:h-24 opacity-40 animate-float-slower">
    <svg viewBox="0 0 100 100" fill="none">
      <circle cx="50" cy="50" r="35" stroke="#FFD60A" stroke-width="3" fill="#FFD60A" fill-opacity="0.08"/>
    </svg>
  </div>
  <div class="absolute top-[60%] end-[12%] w-12 h-12 sm:w-20 sm:h-20 opacity-30 animate-float-slow">
    <svg viewBox="0 0 100 100" fill="none">
      <path d="M10 50L50 10L90 50" stroke="#FFD60A" stroke-width="4" stroke-linecap="round" fill="none"/>
    </svg>
  </div>

  <!-- Main content -->
  <div class="relative z-10 flex flex-col items-center text-center pt-24 sm:pt-28 lg:pt-32 px-6 max-w-6xl mx-auto">

    <!-- Headline — display text -->
    <h1 class="font-heading font-black text-[clamp(2.5rem,6vw,5.5rem)] leading-[0.95] tracking-tight">
      {t(locale, 'hero.headline1')}
      <br />
      {t(locale, 'hero.headline2.before')}<span class="text-accent">{t(locale, 'hero.headline2.accent')}</span>{t(locale, 'hero.headline2.after')}
    </h1>

    <!-- Subtitle -->
    <p class="mt-6 sm:mt-8 text-text-secondary text-lg sm:text-xl max-w-2xl leading-relaxed">
      {t(locale, 'hero.subtitle')}
    </p>

    <!-- CTA Button (observed by nav to show/hide nav CTA) -->
    <div id="hero-ctas" class="mt-8 sm:mt-10">
      <a
        href="https://apps.apple.com/us/app/visualise-investments-laak/id6761325373"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block hover:opacity-80 transition-opacity duration-200"
      >
        <img
          src="/images/app-store-badge.svg"
          alt="Download on the App Store"
          class="h-[54px] sm:h-[60px] w-auto"
        />
      </a>
    </div>

    <!-- Stats row -->
    <div class="mt-10 sm:mt-12 flex items-center gap-6 sm:gap-10">
      <div class="text-center">
        <div class="font-heading font-extrabold text-2xl sm:text-3xl text-text-primary">{t(locale, 'hero.stats.stocks')}</div>
        <div class="text-text-muted text-xs sm:text-sm mt-1">{t(locale, 'hero.stats.stocksLabel')}</div>
      </div>
      <div class="w-px h-10 bg-white/10"></div>
      <div class="text-center">
        <div class="font-heading font-extrabold text-2xl sm:text-3xl text-text-primary">{t(locale, 'hero.stats.onDevice')}</div>
        <div class="text-text-muted text-xs sm:text-sm mt-1">{t(locale, 'hero.stats.onDeviceLabel')}</div>
      </div>
      <div class="w-px h-10 bg-white/10"></div>
      <div class="text-center">
        <div class="font-heading font-extrabold text-2xl sm:text-3xl text-text-primary">{t(locale, 'hero.stats.markets')}</div>
        <div class="text-text-muted text-xs sm:text-sm mt-1">{t(locale, 'hero.stats.marketsLabel')}</div>
      </div>
    </div>
  </div>

  <!-- Phone mockups — hidden behind features band, parallax reveals on scroll -->
  <div id="hero-phones" class="relative z-10 mt-12 sm:mt-16 w-full max-w-5xl mx-auto px-6" style="transform: translateY(200px); will-change: transform;">
    <div class="relative flex items-end justify-center h-[380px] sm:h-[480px] lg:h-[580px]">

      <!-- Left phone — Insights (tilted) -->
      <div class="absolute start-[5%] sm:start-[10%] lg:start-[15%] bottom-0 w-[180px] sm:w-[220px] lg:w-[260px] -rotate-6 origin-bottom z-10">
        <div class="rounded-[1.8rem] sm:rounded-[2.2rem] border border-white/10 overflow-hidden shadow-2xl">
          <img
            src="/images/screens/insights.webp"
            alt="Laak insights screen showing portfolio score, compliance status, and AI narrative"
            class="w-full h-auto block"
            width="267"
            height="580"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Center phone — Portfolio (main, larger) -->
      <div class="relative z-20 w-[200px] sm:w-[250px] lg:w-[290px]">
        <div class="gold-glow absolute inset-0 rounded-[2rem] sm:rounded-[2.5rem]"></div>
        <div class="relative rounded-[2rem] sm:rounded-[2.5rem] border-2 border-white/10 overflow-hidden shadow-2xl">
          <img
            src="/images/screens/portfolio.webp"
            alt="Laak portfolio screen showing holdings across cash, gold, and ETFs"
            class="w-full h-auto block"
            width="267"
            height="580"
            loading="eager"
          />
        </div>
      </div>

      <!-- Right phone — Settings (tilted) -->
      <div class="absolute end-[5%] sm:end-[10%] lg:end-[15%] bottom-0 w-[180px] sm:w-[220px] lg:w-[260px] rotate-6 origin-bottom z-10">
        <div class="rounded-[1.8rem] sm:rounded-[2.2rem] border border-white/10 overflow-hidden shadow-2xl">
          <img
            src="/images/screens/settings.webp"
            alt="Laak settings screen with credits, account, and market configuration"
            class="w-full h-auto block"
            width="267"
            height="580"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>

  <script>
    const phones = document.getElementById('hero-phones');
    if (phones) {
      const startY = 200;   // initial offset (hidden below)
      const speed = 0.45;   // parallax speed — how fast phones rise relative to scroll

      function updateParallax() {
        const scrollY = window.scrollY;
        const offset = Math.max(startY - scrollY * speed, -100);
        phones.style.transform = `translateY(${offset}px)`;
      }

      window.addEventListener('scroll', updateParallax, { passive: true });
      updateParallax();
    }
  </script>
</section>
