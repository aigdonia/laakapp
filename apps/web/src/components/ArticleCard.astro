---
import type { Locale } from '../i18n/config';
import { localePath } from '../i18n/utils';

interface Props {
  article: {
    title: string;
    slug: string;
    summary: string;
    coverImage: string | null;
    author: string | null;
    publishedAt: string | null;
  };
  category?: { title: string; icon: string } | null;
  locale: Locale;
}

const { article, category, locale } = Astro.props;

const date = article.publishedAt
  ? new Date(article.publishedAt).toLocaleDateString(locale === 'ar' ? 'ar-EG' : 'en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    })
  : null;
---

<a
  href={localePath(locale, `/learn/${article.slug}`)}
  class="group block rounded-2xl overflow-hidden border border-white/[0.06] bg-surface-light hover:border-accent/30 transition-all duration-300 animate-on-scroll"
>
  {/* Cover image or gradient placeholder */}
  <div class="aspect-[16/9] overflow-hidden">
    {article.coverImage ? (
      <img
        src={article.coverImage}
        alt={article.title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full bg-gradient-to-br from-surface-lighter to-surface flex items-center justify-center">
        <span class="text-4xl opacity-30">{category?.icon ?? '📝'}</span>
      </div>
    )}
  </div>

  <div class="p-5 flex flex-col gap-3">
    {/* Category badge */}
    {category && (
      <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-accent uppercase tracking-widest w-fit">
        <span>{category.icon}</span>
        {category.title}
      </span>
    )}

    {/* Title */}
    <h3 class="font-heading font-bold text-lg text-text-primary leading-snug group-hover:text-accent transition-colors line-clamp-2">
      {article.title}
    </h3>

    {/* Summary */}
    {article.summary && (
      <p class="text-text-secondary text-sm leading-relaxed line-clamp-2">
        {article.summary}
      </p>
    )}

    {/* Meta row */}
    <div class="flex items-center gap-3 text-text-muted text-xs mt-auto pt-1">
      {article.author && <span>{article.author}</span>}
      {article.author && date && <span class="opacity-40">·</span>}
      {date && <span>{date}</span>}
    </div>
  </div>
</a>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
