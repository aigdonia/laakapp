---
const currentYear = new Date().getFullYear();
---

<section id="download" class="py-28 sm:py-36 lg:py-44 relative overflow-hidden">
  <!-- Gold glow -->
  <div class="absolute top-1/2 start-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] rounded-full bg-accent/[0.06] blur-[150px]"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center animate-on-scroll">
    <h2 class="font-heading font-black text-[clamp(2.5rem,6vw,5rem)] leading-[1] tracking-tight">
      STOP GUESSING.<br />
      START <span class="text-accent">SEEING.</span>
    </h2>
    <p class="mt-6 text-text-secondary text-lg sm:text-xl max-w-xl mx-auto leading-relaxed">
      Track your investment portfolio with full privacy. No account needed.
    </p>

    <!-- CTA buttons -->
    <div class="mt-12 flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="#"
        class="inline-flex items-center justify-center gap-2.5 bg-accent text-surface font-bold rounded-full px-10 py-4 text-base hover:scale-105 hover:shadow-[0_0_30px_rgba(255,214,10,0.3)] transition-all duration-200"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        App Store
      </a>
      <a
        href="#"
        class="inline-flex items-center justify-center gap-2.5 bg-white/[0.06] hover:bg-white/10 border border-white/10 text-text-primary font-bold rounded-full px-10 py-4 text-base transition-all"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.198l2.807 1.626a1 1 0 010 1.73l-2.808 1.626L15.206 12l2.492-2.491zM5.864 2.658L16.802 8.99l-2.303 2.303-8.635-8.635z"/>
        </svg>
        Google Play
      </a>
    </div>
  </div>
</section>

<footer class="border-t border-white/[0.06] py-10">
  <div class="max-w-[90rem] mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-2.5">
      <img src="/images/laak-logo.svg" alt="Laak" class="h-6 w-auto invert opacity-60" />
      <span class="text-text-muted text-sm">&copy; {currentYear} Laak. All rights reserved.</span>
    </div>

    <div class="flex items-center gap-6">
      <a href="/privacy" class="text-text-muted hover:text-text-secondary text-sm transition-colors">Privacy Policy</a>
      <a href="/terms" class="text-text-muted hover:text-text-secondary text-sm transition-colors">Terms</a>
    </div>
  </div>
</footer>
