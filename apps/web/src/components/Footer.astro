---
import type { Locale } from '../i18n/config';
import { t, localePath } from '../i18n/utils';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const currentYear = new Date().getFullYear();
---

<section id="download" class="py-28 sm:py-36 lg:py-44 relative overflow-hidden">
  <!-- Gold glow -->
  <div class="absolute top-1/2 start-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] rounded-full bg-accent/[0.06] blur-[150px]"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center animate-on-scroll">
    <h2 class="font-heading font-black text-[clamp(2.5rem,6vw,5rem)] leading-[1] tracking-tight">
      {t(locale, 'footer.heading1')}<br />
      {t(locale, 'footer.heading2.before')}<span class="text-accent">{t(locale, 'footer.heading2.accent')}</span>
    </h2>
    <p class="mt-6 text-text-secondary text-lg sm:text-xl max-w-xl mx-auto leading-relaxed">
      {t(locale, 'footer.subtitle')}
    </p>

    <!-- CTA buttons -->
    <div class="mt-12 flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a
        href="https://apps.apple.com/us/app/visualise-investments-laak/id6761325373"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block hover:opacity-80 transition-opacity duration-200"
      >
        <img
          src="/images/app-store-badge.svg"
          alt="Download on the App Store"
          class="h-[54px] w-auto"
        />
      </a>
      <a
        href="https://play.google.com/store/apps/details?id=tech.olanai.finapp"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block hover:opacity-80 transition-opacity duration-200"
      >
        <img
          src="/images/google-play-badge.png"
          alt="Get it on Google Play"
          class="h-[54px] w-auto"
        />
      </a>
    </div>
  </div>
</section>

<footer class="border-t border-white/[0.06] py-10">
  <div class="max-w-[90rem] mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-2.5">
      <img src="/images/laak-logo.svg" alt="Laak" class="h-6 w-auto invert opacity-60" />
      <span class="text-text-muted text-sm">&copy; {currentYear} {t(locale, 'footer.copyright')}</span>
    </div>

    <div class="flex items-center gap-6">
      <a href={localePath(locale, '/privacy')} class="text-text-muted hover:text-text-secondary text-sm transition-colors">{t(locale, 'footer.privacyLink')}</a>
      <a href={localePath(locale, '/terms')} class="text-text-muted hover:text-text-secondary text-sm transition-colors">{t(locale, 'footer.termsLink')}</a>
      <a href={localePath(locale, '/support')} class="text-text-muted hover:text-text-secondary text-sm transition-colors">{t(locale, 'footer.supportLink')}</a>
    </div>
  </div>
</footer>
