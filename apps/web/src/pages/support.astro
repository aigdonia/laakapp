---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import { t, localePath } from '../i18n/utils';
import { API_URL } from 'astro:env/server';
import { marked } from 'marked';

import '@fontsource-variable/nunito-sans';
import '@fontsource/geist-sans/400.css';
import '@fontsource/geist-sans/500.css';
import '@fontsource/geist-sans/600.css';
import '@fontsource/geist-sans/700.css';
import '@fontsource/lora/400.css';
import '../styles/global.css';

const locale = 'en' as const;

// Fetch support articles from API at build time
const allArticles: { id: string; title: string; slug: string; summary: string; body: string; status: string; categoryId: string | null; languageCode: string }[] =
  await fetch(`${API_URL}/articles`).then((r) => r.json()).catch(() => []);
const categories: { id: string; slug: string }[] =
  await fetch(`${API_URL}/article-categories`).then((r) => r.json()).catch(() => []);

const supportCategory = categories.find((c) => c.slug === 'support');
const articles = supportCategory
  ? allArticles.filter((a) => a.categoryId === supportCategory.id && a.status === 'published' && a.languageCode === 'en')
  : [];
---

<Layout
  locale={locale}
  title={t(locale, 'support.page.title')}
  description={t(locale, 'support.page.description')}
>
  <Nav locale={locale} />

  <main class="pt-28 sm:pt-36 pb-20 sm:pb-28">
    <div class="max-w-5xl mx-auto px-6">
      <!-- Header -->
      <div class="mb-12 animate-on-scroll">
        <p class="text-accent font-semibold text-sm uppercase tracking-widest mb-3">{t(locale, 'support.label')}</p>
        <h1 class="font-heading font-black text-[clamp(2rem,5vw,3.5rem)] leading-[1.1] tracking-tight">
          {t(locale, 'support.page.heading')}
        </h1>
        <p class="mt-4 text-text-secondary text-lg leading-relaxed">
          {t(locale, 'support.page.subtitle')}
        </p>
      </div>

      <div class="flex flex-col lg:flex-row gap-12">
        <!-- Table of contents (sticky sidebar) -->
        {articles.length > 0 && (
          <nav class="lg:w-56 shrink-0">
            <div class="lg:sticky lg:top-28">
              <p class="text-text-muted text-xs uppercase tracking-widest font-semibold mb-4">{t(locale, 'support.toc')}</p>
              <ul class="flex flex-row flex-wrap lg:flex-col gap-2">
                {articles.map((article) => (
                  <li>
                    <a
                      href={`#${article.slug}`}
                      class="text-text-muted hover:text-accent text-sm transition-colors"
                    >
                      {article.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </nav>
        )}

        <!-- Support content from API -->
        <div class="prose flex-1 min-w-0">
          {articles.map((article) => (
            <section id={article.slug}>
              <h2>{article.title}</h2>
              <Fragment set:html={marked.parse(article.body)} />
            </section>
          ))}
          {articles.length === 0 && (
            <p class="text-text-muted">{t(locale, 'support.empty')}</p>
          )}
        </div>
      </div>
    </div>
  </main>

  <!-- Minimal footer -->
  <footer class="border-t border-white/[0.06] py-10">
    <div class="max-w-[90rem] mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2.5">
        <img src="/images/laak-logo.svg" alt="Laak" class="h-6 w-auto invert opacity-60" />
        <span class="text-text-muted text-sm">&copy; {new Date().getFullYear()} {t(locale, 'footer.copyright')}</span>
      </div>
      <div class="flex items-center gap-6">
        <a href={localePath(locale, '/')} class="text-text-muted hover:text-text-secondary text-sm transition-colors">{t(locale, 'legal.home')}</a>
        <a href={localePath(locale, '/privacy')} class="text-text-muted hover:text-text-secondary text-sm transition-colors">{t(locale, 'legal.privacy')}</a>
        <a href={localePath(locale, '/terms')} class="text-text-muted hover:text-text-secondary text-sm transition-colors">{t(locale, 'legal.terms')}</a>
        <a href={localePath(locale, '/support')} class="text-text-secondary text-sm transition-colors">{t(locale, 'footer.supportLink')}</a>
      </div>
    </div>
  </footer>
</Layout>

