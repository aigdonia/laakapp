---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import TermsEN from '../content/terms-en.astro';
import { t, localePath } from '../i18n/utils';

import '@fontsource-variable/nunito-sans';
import '@fontsource/geist-sans/400.css';
import '@fontsource/geist-sans/500.css';
import '@fontsource/geist-sans/600.css';
import '@fontsource/geist-sans/700.css';
import '@fontsource/lora/400.css';
import '../styles/global.css';

const locale = 'en' as const;
---

<Layout
  locale={locale}
  title={t(locale, 'terms.page.title')}
  description={t(locale, 'terms.page.description')}
>
  <Nav locale={locale} />

  <main class="pt-28 sm:pt-36 pb-20 sm:pb-28">
    <article class="max-w-3xl mx-auto px-6">
      <!-- Header -->
      <div class="mb-12 animate-on-scroll">
        <p class="text-accent font-semibold text-sm uppercase tracking-widest mb-3">{t(locale, 'legal.label')}</p>
        <h1 class="font-heading font-black text-[clamp(2rem,5vw,3.5rem)] leading-[1.1] tracking-tight">
          {t(locale, 'terms.page.heading')}
        </h1>
        <p class="mt-4 text-text-secondary text-lg leading-relaxed">
          {t(locale, 'terms.page.subtitle')}
        </p>
        <p class="mt-2 text-text-muted text-sm">{t(locale, 'terms.page.lastUpdated')}</p>
      </div>

      <!-- Terms Content -->
      <div class="prose">
        <TermsEN />
      </div>
    </article>
  </main>

  <!-- Minimal footer for legal page -->
  <footer class="border-t border-white/[0.06] py-10">
    <div class="max-w-[90rem] mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2.5">
        <img src="/images/laak-logo.svg" alt="Laak" class="h-6 w-auto invert opacity-60" />
        <span class="text-text-muted text-sm">&copy; {new Date().getFullYear()} {t(locale, 'footer.copyright')}</span>
      </div>
      <div class="flex items-center gap-6">
        <a href={localePath(locale, '/')} class="text-text-muted hover:text-text-secondary text-sm transition-colors">{t(locale, 'legal.home')}</a>
        <a href={localePath(locale, '/privacy')} class="text-text-muted hover:text-text-secondary text-sm transition-colors">{t(locale, 'legal.privacy')}</a>
        <a href={localePath(locale, '/terms')} class="text-text-secondary text-sm transition-colors">{t(locale, 'legal.terms')}</a>
      </div>
    </div>
  </footer>
</Layout>

<style>
  /* Prose styling for legal content */
  .prose :global(h2) {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.375rem;
    color: var(--color-text-primary);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .prose :global(h3) {
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--color-text-primary);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .prose :global(p) {
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .prose :global(ul) {
    list-style: none;
    padding-inline-start: 0;
    margin-bottom: 1rem;
  }

  .prose :global(ul li) {
    color: var(--color-text-secondary);
    line-height: 1.75;
    padding-inline-start: 1.5rem;
    position: relative;
    margin-bottom: 0.375rem;
  }

  .prose :global(ul li::before) {
    content: '';
    position: absolute;
    inset-inline-start: 0;
    top: 0.7rem;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    opacity: 0.6;
  }

  .prose :global(strong) {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .prose :global(a:hover) {
    opacity: 0.8;
  }

  .prose :global(.callout) {
    background: rgba(255, 214, 10, 0.06);
    border-inline-start: 3px solid var(--color-accent);
    border-radius: 0 0.5rem 0.5rem 0;
    padding: 1rem 1.25rem;
    margin: 1.25rem 0;
  }

  .prose :global(.callout p) {
    margin-bottom: 0;
    color: var(--color-text-primary);
  }
</style>
