{
  "name": "@fin-ai/mobile",
  "main": "expo-router/entry",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "dev": "expo start",
    "android": "JAVA_HOME=/opt/homebrew/opt/openjdk@17/libexec/openjdk.jdk/Contents/Home expo run:android",
    "android:prod": "JAVA_HOME=/opt/homebrew/opt/openjdk@17/libexec/openjdk.jdk/Contents/Home APP_ENV=production expo run:android --variant release",
    "android:bundle": "JAVA_HOME=/opt/homebrew/opt/openjdk@17/libexec/openjdk.jdk/Contents/Home ./android/gradlew -p android app:bundleRelease && open android/app/build/outputs/bundle/release/",
    "ios": "expo run:ios",
    "ios:prod": "APP_ENV=production expo run:ios --configuration Release",
    "build:ios": "expo run:ios --device --configuration Release",
    "bump:ios": "node -e \"const fs=require('fs');const f='app.config.ts';let s=fs.readFileSync(f,'utf8');const m=s.match(/buildNumber:\\s*[\\\"'](\\d+)[\\\"']/);const n=m?Number(m[1])+1:1;s=s.replace(/buildNumber:\\s*[\\\"']\\d+[\\\"']/,'buildNumber: \\\"'+n+'\\\"');fs.writeFileSync(f,s);console.log('iOS buildNumber:',n)\"",
    "bump:android": "node -e \"const fs=require('fs');const f='app.config.ts';let s=fs.readFileSync(f,'utf8');const m=s.match(/versionCode:\\s*(\\d+)/);const n=m?Number(m[1])+1:1;s=s.replace(/versionCode:\\s*\\d+/,'versionCode: '+n);fs.writeFileSync(f,s);console.log('Android versionCode:',n)\"",
    "bump:build": "echo 'Use bump:ios or bump:android individually'",
    "prep:archive": "pnpm bump:ios && npx expo prebuild",
    "prep:bundle": "pnpm bump:android && npx expo prebuild",
    "archive": "pnpm prep:archive && xcodebuild -workspace ios/Laak.xcworkspace -scheme Laak -configuration Release -destination 'generic/platform=iOS' -derivedDataPath ios/build/DerivedData -archivePath ios/build/Laak.xcarchive archive && open ios/build/Laak.xcarchive",
    "bundle:android": "pnpm prep:bundle && JAVA_HOME=/opt/homebrew/opt/openjdk@17/libexec/openjdk.jdk/Contents/Home ./android/gradlew -p android app:bundleRelease && open android/app/build/outputs/bundle/release/",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:generate:app": "drizzle-kit generate --config drizzle-app.config.ts"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@fin-ai/shared": "workspace:*",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-navigation/native": "^7.1.34",
    "@shopify/react-native-skia": "2.2.12",
    "@supabase/supabase-js": "^2.100.1",
    "@tabler/icons-react-native": "^3.40.0",
    "@tanstack/react-query": "^5.94.5",
    "drizzle-orm": "^0.38.0",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-application": "~7.0.8",
    "expo-build-disk-cache": "^0.7.3",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-device": "^55.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "^15.0.8",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-localization": "^17.0.8",
    "expo-notifications": "^0.32.16",
    "expo-router": "~6.0.23",
    "expo-screen-capture": "^55.0.9",
    "expo-secure-store": "^15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "^16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-tracking-transparency": "~6.0.8",
    "expo-web-browser": "~15.0.10",
    "i18next": "^25.10.9",
    "posthog-react-native": "^4.39.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.6.6",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-mmkv": "^4.3.0",
    "react-native-purchases": "^9.14.0",
    "react-native-reanimated": "4.1.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "tailwindcss": "^4",
    "uniwind": "^1.6.0",
    "victory-native": "^41.20.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.1.17",
    "drizzle-kit": "^0.30.0",
    "typescript": "~5.9.2"
  }
}
